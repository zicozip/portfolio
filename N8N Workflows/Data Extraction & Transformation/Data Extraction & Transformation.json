    {
      "parameters": {
        "jsCode": "// File Type Check - CORRECTED to preserve binary data\nconst item = $input.first();\nconst fileData = item.binary?.data || item.binary?.data0;\n\nif (!fileData) {\n  throw new Error('No file received. Please upload a file.');\n}\n\nconst allowedTypes = [\n  'application/pdf',\n  'image/jpeg', \n  'image/jpg',\n  'image/png',\n  'text/csv',\n  'application/vnd.ms-excel',\n  'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'\n];\n\nconst fileType = fileData.mimeType;\nconst fileName = fileData.fileName || 'uploaded_file';\nconst fileSize = fileData.fileSize || 0;\n\nif (fileSize > 10 * 1024 * 1024) {\n  throw new Error(`File too large: ${Math.round(fileSize/1024/1024)}MB. Maximum size is 10MB.`);\n}\n\nif (!allowedTypes.includes(fileType)) {\n  throw new Error(`File type \"${fileType}\" not supported. Supported: PDF, JPG, PNG, CSV, Excel`);\n}\n\n// CRITICAL: Return as array with both json and binary preserved\nreturn [{\n  json: {\n    fileName: fileName,\n    fileType: fileType,\n    fileSize: fileSize,\n    fileSizeMB: Math.round(fileSize / 1024 / 1024 * 100) / 100,\n    timestamp: new Date().toISOString(),\n    status: 'valid_file'\n  },\n  binary: item.binary  // Preserve ALL binary data from input\n}];"
      },
