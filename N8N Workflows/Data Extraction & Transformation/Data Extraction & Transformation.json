    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4.1-mini",
          "mode": "list",
          "cachedResultName": "GPT-4.1-MINI"
        },
        "messages": {
          "values": [
            {
              "content": "You are a manufacturing data extraction specialist. Extract structured data and return ONLY valid JSON using straight quotes only.\n\nCRITICAL: Use only straight quotes (\") in JSON. Never use smart quotes, curly quotes, or special characters.\n\nReplace any special characters in descriptions:\n- Use 'inch' instead of \" symbol\n- Use 'feet' instead of ' symbol  \n- Use regular apostrophes, not smart quotes\n\nThis ensures clean JSON parsing.",
              "role": "system"
            },
            {
              "content": "=Extract manufacturing data from this document:\\n\\nDocument Type: {{ $json.sourceType }}\\nFile Name: {{ $json.originalFileName }}\\nExtraction Method: {{ $json.extractionMethod }}\\n\\nContent:\\n{{ $json.extractedText }}"
            }
          ]
        },
        "options": {
          "maxTokens": 1000,
          "temperature": 0.1
        }
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [
        -96,
        1056
      ],
      "id": "88403867-d5e6-46aa-9462-b91038ec1725",
      "name": "Message a model",
      "credentials": {
        "openAiApi": {
          "id": "6zNcL0mVed9PBJ6M",
          "name": "n8n free OpenAI API credits"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Simplified Node 7 - just parse OpenAI response\nconst openaiResponse = $input.first().json;\nlet extractedData;\n\ntry {\n  let jsonString = openaiResponse.message.content\n    .replace(/\"/g, '\"')\n    .replace(/\"/g, '\"')\n    .replace(/'/g, \"'\")\n    .replace(/'/g, \"'\");\n  \n  extractedData = JSON.parse(jsonString);\n  extractedData.extractionMethod = \"openai_parsed\";\n  \n} catch (error) {\n  const rawResponse = openaiResponse.message.content;\n  const invoiceMatch = rawResponse.match(/\"invoiceNumber\":\\s*\"([^\"]+)\"/);\n  const supplierMatch = rawResponse.match(/\"supplierName\":\\s*\"([^\"]+)\"/);\n  const totalMatch = rawResponse.match(/\"totalAmount\":\\s*([0-9.]+)/);\n  \n  extractedData = {\n    invoiceNumber: invoiceMatch ? invoiceMatch[1] : \"PARSE_ERROR\",\n    supplierName: supplierMatch ? supplierMatch[1] : \"PARSE_ERROR\", \n    totalAmount: totalMatch ? parseFloat(totalMatch[1]) : 0,\n    extractionMethod: \"regex_fallback\"\n  };\n}\n\nreturn extractedData;"
      },
