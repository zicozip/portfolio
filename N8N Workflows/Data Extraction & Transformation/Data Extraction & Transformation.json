    {
      "parameters": {
        "jsCode": "// OCR placeholder for images - would integrate with Google Vision API in production\nreturn {\n  text: \"Sample invoice extracted from image:\\n\\nINVOICE #INV-2024-001\\nDate: 2024-09-12\\nSupplier: Manufacturing Supply Co.\\nTotal: $1,250.00\\n\\nLine Items:\\n- Steel sheets (5 units) - $750.00\\n- Bolts (100 pieces) - $500.00\",\n  extractionMethod: \"ocr_simulation\",\n  confidence: 0.85,\n  ocrProvider: \"placeholder\",\n  note: \"This is simulated OCR data. In production, integrate with Google Vision API or AWS Textract.\"\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        656,
        864
      ],
      "id": "0de38f24-1567-4c29-bc5b-1d2354134841",
      "name": "OCR Image Text"
    },
    {
      "parameters": {
        "numberInputs": 5
      },
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [
        1008,
        624
      ],
      "id": "ac001d6b-e93b-4506-9f8b-7601f5ef5fa4",
      "name": "Merge"
    },
    {
      "parameters": {
        "jsCode": "// Standardize extracted data from different file types into consistent format\nconst input = $input.first().json;\nconst originalData = $('File Validation').first().json;\n\nlet extractedText = '';\nlet extractionMethod = '';\nlet sourceType = '';\nlet confidence = 1.0;\n\n// Handle different extraction outputs based on structure\nif (input.text && typeof input.text === 'string') {\n  // PDF extraction or OCR result\n  extractedText = input.text;\n  \n  if (input.extractionMethod === 'ocr_simulation') {\n    extractionMethod = 'ocr_simulation';\n    sourceType = 'image';\n    confidence = input.confidence || 0.85;\n  } else {\n    extractionMethod = 'pdf_extraction';\n    sourceType = 'document';\n    confidence = 0.95;\n  }\n  \n} else if (Array.isArray(input) && input.length > 0) {\n  // Excel/CSV extraction (structured data as array)\n  const firstRow = input[0];\n  const headers = Object.keys(firstRow || {});\n  const dataRows = input.slice(0, 10); // First 10 rows for AI processing\n  \n  // Convert structured data to readable text\n  extractedText = `Spreadsheet Data:\\n\\nColumns: ${headers.join(', ')}\\n\\nSample Data:\\n`;\n  extractedText += dataRows.map((row, index) => {\n    const rowData = headers.map(col => `${col}: ${row[col] || 'N/A'}`).join(', ');\n    return `Row ${index + 1}: ${rowData}`;\n  }).join('\\n');\n  \n  extractionMethod = 'structured_data';\n  sourceType = 'spreadsheet';\n  confidence = 0.98;\n  \n} else if (input.numpages) {\n  // PDF metadata object (fallback case)\n  extractedText = input.text || 'No text extracted from PDF';\n  extractionMethod = 'pdf_extraction';\n  sourceType = 'document';  \n  confidence = 0.90;\n  \n} else {\n  // Unknown format fallback\n  extractedText = `Data: ${JSON.stringify(input).substring(0, 800)}`;\n  extractionMethod = 'raw_fallback';\n  sourceType = 'unknown';\n  confidence = 0.5;\n}\n\n// Trim text for AI processing (OpenAI token limits)\nif (extractedText.length > 4000) {\n  extractedText = extractedText.substring(0, 4000) + '\\n...[content truncated for AI processing]';\n}\n\n// Return standardized format ready for AI\nreturn {\n  extractedText: extractedText,\n  extractionMethod: extractionMethod,\n  sourceType: sourceType,\n  confidence: confidence,\n  \n  // Original file metadata\n  originalFileName: originalData.fileName,\n  originalFileType: originalData.fileType,\n  originalFileSize: originalData.fileSize,\n  \n  // Processing metadata\n  processedAt: new Date().toISOString(),\n  textLength: extractedText.length,\n  readyForAI: extractedText.length > 50,\n  \n  // For debugging\n  inputStructure: Array.isArray(input) ? 'array' : typeof input\n};"
      },
